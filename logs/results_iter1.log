    interp_lb_from_z = interpolate.interp1d(
        z_plot, lb_plot, bounds_error=False, fill_value='extrapolate')

    gems_zform = gems_df['z_form'].values
    gems_zform_lo = gems_df['z_form_lower'].values
    gems_zform_hi = gems_df['z_form_upper'].values
    sparkler_zform = sparkler_df['z_form'].values
    sparkler_zform_lo = sparkler_df['z_form_lower'].values
    sparkler_zform_hi = sparkler_df['z_form_upper'].values

    gems_xerr_lo = np.clip(gems_zform - gems_zform_lo, 0.0, None)
    gems_xerr_hi = np.clip(gems_zform_hi - gems_zform, 0.0, None)
    sparkler_xerr_lo = np.clip(sparkler_zform - sparkler_zform_lo, 0.0, None)
    sparkler_xerr_hi = np.clip(sparkler_zform_hi - sparkler_zform, 0.0, None)

    print('\n--- Summary Statistics ---')
    print('GEMS z_form: mean=' + str(round(float(np.mean(gems_zform)), 3))
          + ', median=' + str(round(float(np.median(gems_zform)), 3))
          + ', std=' + str(round(float(np.std(gems_zform)), 3))
