    gems_df = pd.DataFrame(gems_data, columns=['name', 'log10_mass', 'age_Gyr', 'age_err_lo', 'age_err_hi', 'ZH', 'ZH_err_lo', 'ZH_err_hi'])
    gems_df['system'] = 'GEMS'; gems_df['z_obs'] = 9.625
    sparkler_data = [
