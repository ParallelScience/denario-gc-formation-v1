        ('SP10', 6.944087, 1.660122, 1.029555, 0.969398, -0.185263, 0.190706, 0.366281),
    ]
    sparkler_df = pd.DataFrame(sparkler_data, columns=['name', 'log10_mass', 'age_Gyr', 'age_err_lo', 'age_err_hi', 'ZH', 'ZH_err_lo', 'ZH_err_hi'])
    sparkler_df['system'] = 'Sparkler'; sparkler_df['z_obs'] = 1.4
    return gems_df, sparkler_df

def process_gc_dataframe(df, cosmo, z_grid, age_grid):
    z_form_list, z_form_lower_list, z_form_upper_list = [], [], []
    t_form_list, lookback_list, clamped_list = [], [], []
    for _, row in df.iterrows():
        z_obs, age, age_lo, age_hi = row['z_obs'], row['age_Gyr'], row['age_err_lo'], row['age_err_hi']
        zf, tf, cl = compute_z_form(cosmo, z_obs, age, z_grid, age_grid)
        zf_lower, _, _ = compute_z_form(cosmo, z_obs, age + age_hi, z_grid, age_grid)
        age_young = max(age - age_lo, 0.0)
        zf_upper, _, _ = compute_z_form(cosmo, z_obs, age_young, z_grid, age_grid)
        lb = cosmo.lookback_time(zf).to(u.Gyr).value
        z_form_list.append(zf); z_form_lower_list.append(zf_lower); z_form_upper_list.append(zf_upper); t_form_list.append(tf); lookback_list.append(lb); clamped_list.append(cl)
    df = df.copy()
    df['z_form'] = z_form_list; df['z_form_lower'] = z_form_lower_list; df['z_form_upper'] = z_form_upper_list; df['t_form_gyr'] = t_form_list; df['lookback_time_form_Gyr'] = lookback_list; df['clamped'] = clamped_list
    return df

if __name__ == '__main__':
    cosmo = FlatLambdaCDM(H0=67.4, Om0=0.315)
    z_grid, age_grid = build_age_redshift_lookup(cosmo)
    gems_df, sparkler_df = build_gc_dataframe()
    gems_df = process_gc_dataframe(gems_df, cosmo, z_grid, age_grid)
    sparkler_df = process_gc_dataframe(sparkler_df, cosmo, z_grid, age_grid)
    all_df = pd.concat([gems_df, sparkler_df])
    all_df.to_csv('data/gc_data.csv', index=False)
    print('Saved to data/gc_data.csv')
