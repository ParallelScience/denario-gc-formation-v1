    Delta_c = 18.0 * np.pi**2 + 82.0 * (cosmo.Om(z) - 1.0) - 39.0 * (cosmo.Om(z) - 1.0)**2
    M = (2.0 * kB * T_vir_K / (mu * mp))**(3.0 / 2.0) * (G_SI * Hz * np.sqrt(Delta_c) * (4.0 * np.pi / 3.0)**(1.0 / 3.0))**(-3.0 / 2.0)
    return M / Msun_kg

