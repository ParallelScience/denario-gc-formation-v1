    ax_A = axes2[0]
    ax_A.errorbar(gems_mass, gems_zh, yerr=[gems_zh_lo, gems_zh_hi], fmt='o', color=gems_color, markersize=7, elinewidth=1.2, capsize=3, label='GEMS (N=' + str(len(gems_mass)) + ')', zorder=5, alpha=0.85)
    ax_A.errorbar(sparkler_mass, sparkler_zh, yerr=[sparkler_zh_lo, sparkler_zh_hi], fmt='s', color=sparkler_color, markersize=9, elinewidth=1.2, capsize=3, label='Sparkler (N=' + str(len(sparkler_mass)) + ')', zorder=5, alpha=0.85)
    ax_A.plot(mass_ref, zh_ref, 'k--', lw=1.8, label='Harris+2016 MZR ref', zorder=3)
