        age_err_hi, log10_mass, ZH, ZH_err_lo, ZH_err_hi,
        z_form, z_form_lower_bound, z_form_upper_bound.
    """
    gems_names = [
        'J1','I1','H1','G1','A1','B1','C1','D1','E1','F1',
