    ax_B.errorbar(sparkler_zform, sparkler_zh, xerr=[sparkler_xerr_lo, sparkler_xerr_hi], yerr=[sparkler_zh_lo, sparkler_zh_hi], fmt='s', color=sparkler_color, markersize=9, elinewidth=1.0, capsize=3, label='Sparkler (z_obs=1.4)', zorder=5, alpha=0.85)
