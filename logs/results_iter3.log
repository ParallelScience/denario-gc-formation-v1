        [6.944087, 1.660122, 1.029555, 0.969398, -0.185263, 0.190706, 0.366281],
    ])

    z_gems = 9.625
    z_sparkler = 1.4

    lt_gems = cosmo.lookback_time(z_gems).to(u.Gyr).value
    lt_sparkler = cosmo.lookback_time(z_sparkler).to(u.Gyr).value

    rows = []

    for i, name in enumerate(gems_names):
        log10_mass = gems_data[i, 0]
        age        = gems_data[i, 1]
        age_err_lo = gems_data[i, 2]
        age_err_hi = gems_data[i, 3]
        ZH         = gems_data[i, 4]
        ZH_err_lo  = gems_data[i, 5]
        ZH_err_hi  = gems_data[i, 6]

        lt_form_med = lt_gems - age
        lt_form_lo  = lt_gems - (age + age_err_hi)
        lt_form_hi  = lt_gems - (age - age_err_lo)

        z_form_med = compute_z_form(lt_form_med, cosmo)
        z_form_lo  = compute_z_form(lt_form_lo,  cosmo)
        z_form_hi  = compute_z_form(lt_form_hi,  cosmo)

        if np.isnan(z_form_med):
            print("WARNING: Invalid z_form for GEMS cluster " + name +
                  " (lt_form=" + str(round(lt_form_med, 4)) + " Gyr)")

        rows.append({
            'system': 'GEMS',
            'name': name,
            'z_obs': z_gems,
            'age_Gyr': age,
            'age_err_lo': age_err_lo,
            'age_err_hi': age_err_hi,
            'log10_mass': log10_mass,
            'ZH': ZH,
            'ZH_err_lo': ZH_err_lo,
            'ZH_err_hi': ZH_err_hi,
            'z_form': z_form_med,
            'z_form_lower_bound': z_form_lo,
            'z_form_upper_bound': z_form_hi,
        })

    for i, name in enumerate(sparkler_names):
        log10_mass = sparkler_data[i, 0]
        age        = sparkler_data[i, 1]
        age_err_lo = sparkler_data[i, 2]
        age_err_hi = sparkler_data[i, 3]
        ZH         = sparkler_data[i, 4]
        ZH_err_lo  = sparkler_data[i, 5]
        ZH_err_hi  = sparkler_data[i, 6]

        lt_form_med = lt_sparkler - age
        lt_form_lo  = lt_sparkler - (age + age_err_hi)
        lt_form_hi  = lt_sparkler - (age - age_err_lo)

        z_form_med = compute_z_form(lt_form_med, cosmo)
        z_form_lo  = compute_z_form(lt_form_lo,  cosmo)
        z_form_hi  = compute_z_form(lt_form_hi,  cosmo)

        if np.isnan(z_form_med):
            print("WARNING: Invalid z_form for Sparkler cluster " + name +
                  " (lt_form=" + str(round(lt_form_med, 4)) + " Gyr)")

        rows.append({
            'system': 'Sparkler',
            'name': name,
            'z_obs': z_sparkler,
            'age_Gyr': age,
            'age_err_lo': age_err_lo,
            'age_err_hi': age_err_hi,
            'log10_mass': log10_mass,
            'ZH': ZH,
            'ZH_err_lo': ZH_err_lo,
            'ZH_err_hi': ZH_err_hi,
            'z_form': z_form_med,
            'z_form_lower_bound': z_form_lo,
            'z_form_upper_bound': z_form_hi,
        })

    df = pd.DataFrame(rows)
    return df


if __name__ == '__main__':
