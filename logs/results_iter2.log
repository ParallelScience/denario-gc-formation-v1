    print("\nGEMS system:")
    print("  Median log10(M_star/Msolar) = " + "%.4f" % median_logm_gems)
    print("  Median z_form               = " + "%.4f" % median_zform_gems)
    print("  MZR predicted 12+log(O/H)   = " + "%.4f" % oh_gems_pred)
    print("  MZR predicted [Z/H]         = " + "%.4f" % zh_gems_pred)
