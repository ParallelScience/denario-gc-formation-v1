    print('  epsilon=0.01: log10(M_halo) = ' + '%.3f' % np.min(sparkler_halo_hi) + ' to ' + '%.3f' % np.max(sparkler_halo_hi) + ' (Msolar)')
    mol_cool_lo = 5.0
    mol_cool_hi = 6.0
